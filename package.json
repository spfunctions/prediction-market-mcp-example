{
  "name": "prediction-market-mcp",
  "version": "1.0.0",
  "description": "MCP server that gives AI assistants access to prediction market data — world state, uncertainty index, market detail, and edges.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "prediction-market-mcp": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "prediction-markets",
    "ai-agents",
    "claude",
    "cursor",
    "kalshi",
    "polymarket",
    "world-state",
    "llm-tools"
  ],
  "author": "SimpleFunctions <hello@simplefunctions.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spfunctions/prediction-market-mcp-example"
  },
  "homepage": "https://simplefunctions.dev",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
